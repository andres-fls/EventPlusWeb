<?xml version="1.0" encoding="utf-8"?>
<Report ScriptLanguage="CSharp" ReportInfo.Created="2025-01-01" ReportInfo.Modified="2025-01-01" ReportInfo.CreatorVersion="1.0.0.0">
	<Dictionary>
		<BusinessObjectDataSource Name="Eventos" ReferenceName="Eventos" DataType="System.Int32" Enabled="true">
			<Column Name="NombreEvento" DataType="System.String"/>
			<Column Name="DescripcionEvento" DataType="System.String"/>
			<Column Name="FechaInicioEvento" DataType="System.DateTime"/>
			<Column Name="LugarEvento" DataType="System.String"/>
			<Column Name="NombreCategoria" DataType="System.String"/>
			<Column Name="NombreCreador" DataType="System.String"/>
			<Column Name="TipoEvento" DataType="System.String"/>
			<Column Name="EstadoEvento" DataType="System.String"/>
			<Column Name="CupoMaximo" DataType="System.Int32"/>
			<Column Name="Inscritos" DataType="System.Int32"/>
		</BusinessObjectDataSource>
	</Dictionary>
	<ReportPage Name="Page1" Watermark.Font="Arial, 60pt">
		<ReportTitleBand Name="ReportTitle1" Width="718.2" Height="60">
			<TextObject Name="Text1" Width="718.2" Height="40" Text="REPORTE DE EVENTOS - EVENTPLUS" HorzAlign="Center" Font="Arial, 16pt, style=Bold"/>
			<TextObject Name="Text2" Top="40" Width="718.2" Height="20" Text="[Date]" HorzAlign="Center" Font="Arial, 9pt"/>
		</ReportTitleBand>
		<DataBand Name="Data1" Width="718.2" Height="100" DataSource="Eventos">
			<TextObject Name="Text3" Width="400" Height="20" Text="[Eventos.NombreEvento]" Font="Arial, 11pt, style=Bold"/>
			<TextObject Name="Text4" Top="20" Width="718.2" Height="20" Text="[Eventos.DescripcionEvento]" Font="Arial, 9pt"/>
			<TextObject Name="Text5" Top="40" Width="200" Height="20" Text="Inicio: [Eventos.FechaInicioEvento]" Font="Arial, 9pt"/>
			<TextObject Name="Text6" Top="40" Left="200" Width="200" Height="20" Text="Lugar: [Eventos.LugarEvento]" Font="Arial, 9pt"/>
			<TextObject Name="Text7" Top="40" Left="400" Width="200" Height="20" Text="Categoría: [Eventos.NombreCategoria]" Font="Arial, 9pt"/>
			<TextObject Name="Text8" Top="60" Width="300" Height="20" Text="Creador: [Eventos.NombreCreador]" Font="Arial, 9pt, style=Italic"/>
			<TextObject Name="Text9" Top="60" Left="300" Width="200" Height="20" Text="Tipo: [Eventos.TipoEvento]" Font="Arial, 9pt"/>
			<TextObject Name="Text10" Top="80" Width="200" Height="20" Text="Cupo: [Eventos.Inscritos]/[Eventos.CupoMaximo]" Font="Arial, 9pt"/>
			<TextObject Name="Text11" Top="80" Left="200" Width="200" Height="20" Text="Estado: [Eventos.EstadoEvento]" Font="Arial, 9pt"/>
		</DataBand>
		<PageFooterBand Name="PageFooter1" Width="718.2" Height="30">
			<TextObject Name="Text12" Width="718.2" Height="20" Text="Página [Page] de [TotalPages]" HorzAlign="Center" Font="Arial, 8pt"/>
		</PageFooterBand>
	</ReportPage>
</Report>