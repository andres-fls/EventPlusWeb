<?xml version="1.0" encoding="utf-8"?>
<Report ScriptLanguage="CSharp" ReportInfo.Created="2025-01-01" ReportInfo.Modified="2025-01-01" ReportInfo.CreatorVersion="1.0.0.0">
	<Dictionary>
		<BusinessObjectDataSource Name="Eventos" ReferenceName="Eventos" DataType="System.Int32" Enabled="true">
			<Column Name="Titulo" DataType="System.String"/>
			<Column Name="Descripcion" DataType="System.String"/>
			<Column Name="FechaEvento" DataType="System.DateTime"/>
			<Column Name="Ubicacion" DataType="System.String"/>
			<Column Name="CategoriaNombre" DataType="System.String"/>
			<Column Name="CreadorNombre" DataType="System.String"/>
		</BusinessObjectDataSource>
	</Dictionary>
	<ReportPage Name="Page1" Watermark.Font="Arial, 60pt">
		<ReportTitleBand Name="ReportTitle1" Width="718.2" Height="60">
			<TextObject Name="Text1" Width="718.2" Height="40" Text="REPORTE DE EVENTOS - EVENTPLUS" HorzAlign="Center" Font="Arial, 16pt, style=Bold"/>
			<TextObject Name="Text2" Top="40" Width="718.2" Height="20" Text="[Date]" HorzAlign="Center" Font="Arial, 9pt"/>
		</ReportTitleBand>
		<DataBand Name="Data1" Width="718.2" Height="80" DataSource="Eventos">
			<TextObject Name="Text3" Width="300" Height="20" Text="[Eventos.Titulo]" Font="Arial, 11pt, style=Bold"/>
			<TextObject Name="Text4" Top="20" Width="718.2" Height="20" Text="[Eventos.Descripcion]" Font="Arial, 9pt"/>
			<TextObject Name="Text5" Top="40" Width="200" Height="20" Text="Fecha: [Eventos.FechaEvento]" Font="Arial, 9pt"/>
			<TextObject Name="Text6" Top="40" Left="200" Width="200" Height="20" Text="Ubicación: [Eventos.Ubicacion]" Font="Arial, 9pt"/>
			<TextObject Name="Text7" Top="40" Left="400" Width="200" Height="20" Text="Categoría: [Eventos.CategoriaNombre]" Font="Arial, 9pt"/>
			<TextObject Name="Text8" Top="60" Width="300" Height="20" Text="Creador: [Eventos.CreadorNombre]" Font="Arial, 9pt, style=Italic"/>
		</DataBand>
		<PageFooterBand Name="PageFooter1" Width="718.2" Height="30">
			<TextObject Name="Text9" Width="718.2" Height="20" Text="Página [Page] de [TotalPages]" HorzAlign="Center" Font="Arial, 8pt"/>
		</PageFooterBand>
	</ReportPage>
</Report>