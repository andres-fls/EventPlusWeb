@{
    ViewBag.Title = "Crear Administrador";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center" style="margin-top: 30px;">
    <div class="col-md-6 col-lg-5">
        <div class="card p-4">
            <div class="text-center mb-4">
                <i class="bi bi-person-gear" style="font-size: 3rem; color: #7c3aed;"></i>
                <h2 style="color: #a78bfa; margin-top: 10px;">Nuevo Administrador</h2>
                <p style="color: #888;">Registra un nuevo administrador del sistema</p>
            </div>

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger">
                    <i class="bi bi-exclamation-circle"></i> @TempData["Error"]
                </div>
            }

            <form method="post" action="@Url.Action("CrearAdmin", "Usuarios")">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label class="form-label">Nombre completo</label>
                    <input type="text" name="Nombre"
                           class="form-control @(ViewBag.ErrorNombre != null ? "is-invalid" : "")"
                           placeholder="Nombre del administrador" required />
                    @if (ViewBag.ErrorNombre != null)
                    {
                        <div class="invalid-feedback">@ViewBag.ErrorNombre</div>
                    }
                </div>

                <div class="mb-3">
                    <label class="form-label">Correo electr&#243;nico</label>
                    <input type="email" name="Correo"
                           class="form-control @(ViewBag.ErrorCorreo != null ? "is-invalid" : "")"
                           placeholder="correo@ejemplo.com" required />
                    @if (ViewBag.ErrorCorreo != null)
                    {
                        <div class="invalid-feedback">@ViewBag.ErrorCorreo</div>
                    }
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Contrase&#241;a</label>
                        <input type="password" name="Contrasena"
                               class="form-control @(ViewBag.ErrorContrasena != null ? "is-invalid" : "")"
                               placeholder="M&#237;nimo 6 caracteres" required />
                        @if (ViewBag.ErrorContrasena != null)
                        {
                            <div class="invalid-feedback">@ViewBag.ErrorContrasena</div>
                        }
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Confirmar contrase&#241;a</label>
                        <input type="password" name="ConfirmarContrasena"
                               class="form-control"
                               placeholder="Repite la contrase&#241;a" required />
                    </div>
                </div>

                <div class="d-flex gap-2 mt-3">
                    <button type="submit" class="btn btn-primary w-100 py-2">
                        <i class="bi bi-person-plus"></i> Crear Administrador
                    </button>
                    <a href="@Url.Action("Index", "Usuarios")" class="btn btn-secondary w-100 py-2">
                        <i class="bi bi-arrow-left"></i> Cancelar
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>