@{
    ViewBag.Title = "Registro";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center" style="margin-top: 60px;">
    <div class="col-md-5">
        <div class="card p-4">
            <div class="text-center mb-4">
                <i class="bi bi-person-plus" style="font-size: 3rem; color: #7c3aed;"></i>
                <h2 style="color: #a78bfa; margin-top: 10px;">Crear Cuenta</h2>
                <p style="color: #888;">Regístrate en EventPlus</p>
            </div>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger">
                    <i class="bi bi-exclamation-circle"></i> @ViewBag.Error
                </div>
            }

        <form method="post" action="@Url.Action("Registro", "Usuarios")">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label class="form-label">Nombre completo</label>
                <input type="text" name="Nombre" class="form-control" placeholder="Tu nombre" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Correo electrónico</label>
                <input type="email" name="Correo" class="form-control" placeholder="tucorreo@email.com" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Contraseña</label>
                <input type="password" name="Contrasena" class="form-control" placeholder="••••••••" required />
            </div>
            <button type="submit" class="btn btn-primary w-100 py-2" style="font-size: 1.1rem;">
                <i class="bi bi-person-plus"></i> Registrarse
            </button>
        </form>

            <div class="text-center mt-3">
                <a href="@Url.Action("Login", "Usuarios")" style="color: #a78bfa;">¿Ya tienes cuenta? Inicia sesión</a>
            </div>
        </div>
    </div>
</div>
