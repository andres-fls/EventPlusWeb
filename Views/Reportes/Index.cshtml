@{
    ViewBag.Title = "Reportes";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 style="color: #a78bfa;"><i class="bi bi-file-earmark-pdf"></i> Reportes</h2>
</div>

<div class="row">
    <div class="col-md-6 mb-4">
        <div class="card p-4 text-center">
            <i class="bi bi-calendar3" style="font-size: 3rem; color: #7c3aed;"></i>
            <h4 style="color: #a78bfa; margin-top: 15px;">Reporte de Eventos</h4>
            <p style="color: #888;">Genera un PDF con todos los eventos registrados en el sistema.</p>
            <a href="@Url.Action("EventosPDF", "Reportes")" class="btn btn-primary">
                <i class="bi bi-download"></i> Descargar PDF
            </a>
        </div>
    </div>
    <div class="col-md-6 mb-4">
        <div class="card p-4 text-center">
            <i class="bi bi-people" style="font-size: 3rem; color: #7c3aed;"></i>
            <h4 style="color: #a78bfa; margin-top: 15px;">Reporte de Inscripciones</h4>
            <p style="color: #888;">Genera un PDF con todas las inscripciones por evento.</p>
            <a href="@Url.Action("InscripcionesPDF", "Reportes")" class="btn btn-primary">
                <i class="bi bi-download"></i> Descargar PDF
            </a>
        </div>
    </div>
</div>