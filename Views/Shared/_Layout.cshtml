<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EventPlus - @ViewBag.Title</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />

    @Styles.Render("~/Content/css")

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        /* ===== APLICACIÓN DEL SISTEMA DE TEMAS DINÁMICOS ===== */
        body {
            background-color: var(--bg-principal);
            color: var(--texto-blanco);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            min-height: 100vh;
            transition: background-color 0.3s ease, color 0.3s ease;
        }

        .navbar {
            background-color: var(--bg-tarjetas) !important; /* Muta con el tema */
            border-bottom: 2px solid var(--borde-morado);
            padding: 12px 0;
            transition: background-color 0.3s ease, border-color 0.3s ease;
        }

        .navbar-brand {
            color: var(--morado-resaltado) !important;
            font-weight: bold;
            font-size: 1.4rem;
        }

        .navbar-brand:hover {
            color: var(--borde-morado) !important;
        }

        .nav-link {
            color: var(--texto-blanco) !important; /* Cambia dinámicamente */
            margin: 0 5px;
            transition: color 0.3s;
        }

        .nav-link:hover {
            color: var(--morado-resaltado) !important;
        }

        .nav-link.active {
            color: var(--borde-morado) !important;
            font-weight: bold;
        }

        .container-main {
            padding: 30px 15px;
            max-width: 1200px;
            margin: 0 auto;
        }

        /* ===== BOTONES (IDENTIDAD FIJA) ===== */
        .btn-primary {
            background-color: #7c3aed;
            border-color: #7c3aed;
        }

        .btn-primary:hover {
            background-color: #6d28d9;
            border-color: #6d28d9;
        }

        .btn-danger {
            background-color: #dc2626;
            border-color: #dc2626;
        }

        .btn-success {
            background-color: #059669;
            border-color: #059669;
        }

        /* ===== COMPONENTES QUE MUTAN ===== */
        .card {
            background-color: var(--bg-tarjetas) !important;
            border: 1px solid var(--borde-morado) !important;
            border-radius: 12px;
            transition: background-color 0.3s ease, border-color 0.3s ease;
        }

        .table {
            color: var(--texto-blanco);
        }

        .table thead {
            background-color: var(--borde-morado);
            color: white;
        }

        .table tbody tr {
            background-color: var(--bg-tarjetas);
            border-bottom: 1px solid var(--texto-mutado);
        }

        .form-control, .form-select {
            background-color: var(--bg-tarjetas);
            border: 1px solid var(--texto-mutado);
            color: var(--texto-blanco);
        }

        .form-control:focus, .form-select:focus {
            background-color: var(--bg-tarjetas);
            border-color: var(--borde-morado);
            color: var(--texto-blanco);
            box-shadow: 0 0 0 0.2rem rgba(124, 58, 237, 0.25);
        }

        .form-label {
            color: var(--morado-resaltado);
            font-weight: 500;
        }

        .alert-danger {
            background-color: #4a1515;
            border-color: #dc2626;
            color: #fca5a5;
        }

        .alert-success {
            background-color: #0f3d2e;
            border-color: #059669;
            color: #6ee7b7;
        }

        .user-info {
            color: var(--morado-resaltado);
            font-size: 0.9rem;
        }

        /* ===== DROPDOWN PERFIL ===== */
        .profile-dropdown .dropdown-menu {
            background-color: var(--bg-tarjetas);
            border: 1px solid var(--borde-morado);
            border-radius: 12px;
            padding: 15px;
            min-width: 280px;
        }

        .profile-dropdown .dropdown-menu .profile-header {
            text-align: center;
            padding-bottom: 12px;
            border-bottom: 1px solid var(--texto-mutado);
            margin-bottom: 12px;
        }

        .profile-dropdown .dropdown-menu .profile-header i {
            font-size: 3rem;
            color: var(--borde-morado);
        }

        .profile-dropdown .dropdown-menu .profile-header h6 {
            color: var(--morado-resaltado);
            margin-top: 8px;
            margin-bottom: 2px;
        }

        .profile-dropdown .dropdown-menu .profile-header small {
            color: var(--texto-mutado);
        }

        .profile-dropdown .dropdown-menu .profile-info p {
            color: var(--texto-blanco);
            font-size: 0.85rem;
            margin-bottom: 5px;
        }

        .profile-dropdown .dropdown-menu .profile-info p i {
            color: var(--borde-morado);
            width: 20px;
        }

        /* ===== CHATBOT FLOTANTE ===== */
        .chatbot-btn {
            position: fixed;
            bottom: 25px;
            right: 25px;
            width: 60px;
            height: 60px;
            border-radius: 50%;
            background: linear-gradient(135deg, #7c3aed, #a78bfa);
            border: none;
            color: white;
            font-size: 1.5rem;
            cursor: pointer;
            box-shadow: 0 4px 15px rgba(124, 58, 237, 0.4);
            z-index: 9999;
            transition: transform 0.3s, box-shadow 0.3s;
        }

        .chatbot-btn:hover {
            transform: scale(1.1);
            box-shadow: 0 6px 20px rgba(124, 58, 237, 0.6);
        }

        .chatbot-panel {
            position: fixed;
            bottom: 100px;
            right: 25px;
            width: 370px;
            height: 500px;
            background-color: var(--bg-tarjetas);
            border: 1px solid var(--borde-morado);
            border-radius: 16px;
            display: none;
            flex-direction: column;
            z-index: 9999;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5);
            overflow: hidden;
        }

        .chatbot-panel.active {
            display: flex;
        }

        .chatbot-header {
            background: linear-gradient(135deg, #7c3aed, #6d28d9);
            padding: 15px;
            color: white;
            font-weight: bold;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .chatbot-header button {
            background: none;
            border: none;
            color: white;
            font-size: 1.2rem;
            cursor: pointer;
        }

        .chatbot-messages {
            flex: 1;
            overflow-y: auto;
            padding: 15px;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .chatbot-messages::-webkit-scrollbar {
            width: 6px;
        }

        .chatbot-messages::-webkit-scrollbar-thumb {
            background: var(--borde-morado);
            border-radius: 3px;
        }

        .chat-msg {
            max-width: 80%;
            padding: 10px 14px;
            border-radius: 12px;
            font-size: 0.9rem;
            line-height: 1.4;
        }

        .chat-msg.user {
            align-self: flex-end;
            background-color: #7c3aed;
            color: white;
            border-bottom-right-radius: 4px;
        }

        .chat-msg.bot {
            align-self: flex-start;
            background-color: var(--bg-principal);
            color: var(--texto-blanco);
            border-bottom-left-radius: 4px;
        }

        .chatbot-input {
            display: flex;
            padding: 12px;
            border-top: 1px solid var(--texto-mutado);
            gap: 8px;
        }

        .chatbot-input input {
            flex: 1;
            min-width: 0;
            width: 100%;
            max-width: none;
            background-color: var(--bg-principal);
            border: 1px solid var(--texto-mutado);
            color: var(--texto-blanco);
            border-radius: 8px;
            padding: 10px 12px;
            outline: none;
        }

        .chatbot-input input:focus {
            border-color: var(--borde-morado);
        }

        .chatbot-input button {
            background-color: #7c3aed;
            border: none;
            color: white;
            border-radius: 8px;
            padding: 10px 15px;
            cursor: pointer;
            transition: background-color 0.3s;
            min-width: 46px;
        }

        .chatbot-input button:hover {
            background-color: #6d28d9;
        }

        .chatbot-input button:disabled {
            cursor: not-allowed;
            opacity: 0.65;
        }

        .typing-indicator {
            display: none;
            align-self: flex-start;
            padding: 10px 14px;
            background-color: var(--bg-principal);
            border-radius: 12px;
            font-size: 0.85rem;
            color: var(--morado-resaltado);
        }

        /* ===== CHATBOT RESPONSIVE (MÓVILES Y TABLETAS) ===== */
        @@media (max-width: 768px) {
            .chatbot-btn {
                bottom: 15px;
                right: 15px;
                width: 50px;
                height: 50px;
                font-size: 1.3rem;
            }

            .chatbot-panel {
                bottom: 80px;
                right: 15px;
                left: 15px;
                width: calc(100% - 30px);
                height: 65vh;
                max-height: 450px;
                border-radius: 12px;
            }

            .chatbot-header {
                padding: 12px;
                font-size: 0.95rem;
            }

            .chatbot-messages {
                padding: 10px;
                gap: 8px;
            }

            .chat-msg {
                max-width: 85%;
                padding: 8px 12px;
                font-size: 0.85rem;
            }

            .chatbot-input {
                padding: 10px;
                gap: 6px;
            }

            .chatbot-input input {
                padding: 8px 10px;
                font-size: 0.9rem;
            }

            .chatbot-input button {
                padding: 8px 12px;
            }
        }
        /* Ajustes específicos de contraste para el modo claro */
        small, .text-muted, .profile-dropdown .dropdown-menu .profile-header small {
            color: var(--texto-mutado) !important;
        }

        /* Asegura que los textos dentro de las tarjetas de KPI tengan buena lectura */
        .card p, .card span, .card h3 {
            color: var(--texto-blanco);
        }
        /* Refuerzo para asegurar el contraste de textos en Modo Claro */
        [data-theme="light"] .card,
        [data-theme="light"] .card-body,
        [data-theme="light"] .table tbody tr {
            background-color: var(--bg-tarjetas) !important;
        }

        [data-theme="light"] h3,
        [data-theme="light"] h6,
        [data-theme="light"] span,
        [data-theme="light"] p,
        [data-theme="light"] small,
        [data-theme="light"] .text-muted {
            color: var(--texto-blanco) !important;
        }

        [data-theme="light"] .nav-link {
            color: var(--texto-blanco) !important;
        }

            [data-theme="light"] .nav-link:hover {
                color: var(--morado-resaltado) !important;
            }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container">
            <a class="navbar-brand" href="@Url.Action("Index", "Home")">
                <i class="bi bi-calendar-event"></i> EventPlus
            </a>

            <div class="d-flex align-items-center order-lg-last">
                <button id="btnThemeToggle" class="btn btn-link text-purple-custom fs-4 p-0 me-3" title="Cambiar tema">
                    <i id="themeIcon" class="bi bi-moon-stars-fill"></i>
                </button>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" style="border-color: #7c3aed;">
                    <span class="navbar-toggler-icon"></span>
                </button>
            </div>

            <div class="collapse navbar-collapse" id="navbarNav">
                @if (Session["UsuarioId"] != null)
                {
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("Index", "Eventos")"><i class="bi bi-calendar3"></i> Eventos</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("Index", "Categorias")"><i class="bi bi-tags"></i> Categorías</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("Index", "Reportes")"><i class="bi bi-file-earmark-pdf"></i> Reportes</a>
                        </li>
                        @if (Session["UsuarioRol"] != null && Session["UsuarioRol"].ToString() == "Admin")
                        {
                            <li class="nav-item">
                                <a class="nav-link" href="@Url.Action("Index", "Usuarios")"><i class="bi bi-people"></i> Usuarios</a>
                            </li>
                        }
                    </ul>
                    <ul class="navbar-nav">
                        <li class="nav-item dropdown profile-dropdown">
                            <a class="nav-link dropdown-toggle user-info" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-person-circle"></i> @Session["UsuarioNombre"]
                            </a>
                            <div class="dropdown-menu dropdown-menu-end">
                                <div class="profile-header">
                                    <i class="bi bi-person-circle"></i>
                                    <h6>@Session["UsuarioNombre"]</h6>
                                    <small>@Session["UsuarioCorreo"]</small>
                                    <br />
                                    <span class="badge mt-2" style="background-color: #7c3aed;">@(Session["UsuarioRol"].ToString() == "Usuario" ? "Aprendiz" : Session["UsuarioRol"].ToString())</span>
                                </div>
                                <div class="profile-info">
                                    <p><i class="bi bi-envelope"></i> @Session["UsuarioCorreo"]</p>
                                    <p><i class="bi bi-shield-check"></i> Rol: @(Session["UsuarioRol"].ToString() == "Usuario" ? "Aprendiz" : Session["UsuarioRol"].ToString())</p>
                                </div>
                                <hr style="border-color: #2d2d44; margin: 10px 0;" />
                                <div class="text-center">
                                    <a href="@Url.Action("Logout", "Usuarios")" class="btn btn-sm btn-danger w-100">
                                        <i class="bi bi-box-arrow-right"></i> Cerrar Sesión
                                    </a>
                                </div>
                            </div>
                        </li>
                    </ul>
                }
            </div>
        </div>
    </nav>

    <div class="container-main">
        @RenderBody()
    </div>

    @if (Session["UsuarioId"] != null)
    {
        <button class="chatbot-btn" id="chatbotBtn" title="Asistente EventBot">
            <i class="bi bi-robot"></i>
        </button>

        <div class="chatbot-panel" id="chatbotPanel">
            <div class="chatbot-header">
                <span><i class="bi bi-robot"></i> EventBot</span>
                <button id="chatbotClose"><i class="bi bi-x-lg"></i></button>
            </div>
            <div class="chatbot-messages" id="chatbotMessages">
                <div class="chat-msg bot">¡Hola! Soy EventBot, tu asistente de EventPlus. ¿En qué puedo ayudarte?</div>
            </div>
            <div class="typing-indicator" id="typingIndicator">EventBot está escribiendo...</div>
            <div class="chatbot-input">
                <input type="text" id="chatbotInput" placeholder="Escribe tu mensaje..." />
                <button id="chatbotSend"><i class="bi bi-send"></i></button>
            </div>
        </div>
    }

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // ===== LOGICA CONTROL DE TEMA (CLARO/OSCURO) =====
            const btnToggle = document.getElementById('btnThemeToggle');
            const themeIcon = document.getElementById('themeIcon');
            const htmlElement = document.documentElement;

            // Leer preferencia o asignar Modo Oscuro (removiendo atributo) por defecto
            const temaGuardado = localStorage.getItem('theme') || 'dark';

            if (temaGuardado === 'light') {
                htmlElement.setAttribute('data-theme', 'light');
                if (themeIcon) themeIcon.className = 'bi bi-sun-fill';
            } else {
                htmlElement.removeAttribute('data-theme');
                if (themeIcon) themeIcon.className = 'bi bi-moon-stars-fill';
            }

            if (btnToggle) {
                btnToggle.addEventListener('click', function () {
                    const temaActual = htmlElement.getAttribute('data-theme');
                    if (temaActual === 'light') {
                        htmlElement.removeAttribute('data-theme');
                        localStorage.setItem('theme', 'dark');
                        if (themeIcon) themeIcon.className = 'bi bi-moon-stars-fill';
                    } else {
                        htmlElement.setAttribute('data-theme', 'light');
                        localStorage.setItem('theme', 'light');
                        if (themeIcon) themeIcon.className = 'bi bi-sun-fill';
                    }
                });
            }

            // ===== LOGICA DEL CHATBOT =====
            var chatbotBtn = document.getElementById('chatbotBtn');
            var chatbotPanel = document.getElementById('chatbotPanel');
            var chatbotClose = document.getElementById('chatbotClose');
            var chatbotInput = document.getElementById('chatbotInput');
            var chatbotSend = document.getElementById('chatbotSend');
            var chatbotMessages = document.getElementById('chatbotMessages');
            var typingIndicator = document.getElementById('typingIndicator');

            if (chatbotBtn) {
                chatbotBtn.addEventListener('click', function () {
                    chatbotPanel.classList.toggle('active');
                    if (chatbotPanel.classList.contains('active')) {
                        chatbotInput.focus();
                    }
                });

                chatbotClose.addEventListener('click', function () {
                    chatbotPanel.classList.remove('active');
                });

                chatbotSend.addEventListener('click', enviarMensaje);
                chatbotInput.addEventListener('keypress', function (e) {
                    if (e.key === 'Enter') {
                        enviarMensaje();
                    }
                });
            }

            function enviarMensaje() {
                var mensaje = chatbotInput.value.trim();
                if (mensaje === '') return;

                chatbotSend.disabled = true;
                chatbotInput.disabled = true;

                agregarMensaje(mensaje, 'user');
                chatbotInput.value = '';

                typingIndicator.style.display = 'block';
                chatbotMessages.scrollTop = chatbotMessages.scrollHeight;

                var xhr = new XMLHttpRequest();
                xhr.timeout = 25000;
                xhr.open('POST', '/Chatbot/Enviar', true);
                xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');

                xhr.onreadystatechange = function () {
                    if (xhr.readyState === 4) {
                        typingIndicator.style.display = 'none';
                        chatbotSend.disabled = false;
                        chatbotInput.disabled = false;
                        chatbotInput.focus();

                        if (xhr.status === 200) {
                            try {
                                var data = JSON.parse(xhr.responseText);
                                agregarMensaje(data.respuesta || 'No recibí una respuesta válida.', 'bot');
                            } catch (error) {
                                agregarMensaje('El servidor respondió con un formato inesperado.', 'bot');
                            }
                        } else {
                            agregarMensaje('Error de conexión. Intenta de nuevo.', 'bot');
                        }
                    }
                };

                xhr.ontimeout = function () {
                    typingIndicator.style.display = 'none';
                    chatbotSend.disabled = false;
                    chatbotInput.disabled = false;
                    chatbotInput.focus();
                    agregarMensaje('La respuesta tardó demasiado. Intenta de nuevo.', 'bot');
                };

                xhr.send('mensaje=' + encodeURIComponent(mensaje));
            }

            function agregarMensaje(texto, tipo) {
                var div = document.createElement('div');
                div.className = 'chat-msg ' + tipo;
                div.textContent = texto;
                chatbotMessages.appendChild(div);
                chatbotMessages.scrollTop = chatbotMessages.scrollHeight;
            }
        });
    </script>

    @RenderSection("scripts", required: false)
</body>
</html>