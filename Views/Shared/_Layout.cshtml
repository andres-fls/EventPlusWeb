<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EventPlus - @ViewBag.Title</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />

    @Styles.Render("~/Content/css")

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    /* Forzamos el cambio de variables directamente en el HTML */
    :root {
        --bg-principal: #1e1e24 !important; /* Gris oscuro/antracita más suave (Modo Oscuro) */
    }

    [data-theme="light"] {
        --bg-principal: #eef2f7 !important; /* Gris claro limpio y moderno (Modo Claro) */
    }

    /* Aplicamos el fondo tanto a html como a body para asegurar que cambie */
    html, body {
        background-color: var(--bg-principal) !important;
    }
</style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="navbar-inner">
            <a class="navbar-brand" href="@Url.Action("Index", "Home")">
                <i class="bi bi-calendar-event"></i> EventPlus
            </a>

            <div class="d-flex align-items-center order-lg-last">
                <button id="btnThemeToggle" class="btn btn-link text-purple-custom fs-4 p-0 me-3" title="Cambiar tema">
                    <i id="themeIcon" class="bi bi-moon-stars-fill"></i>
                </button>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
            </div>

            <div class="collapse navbar-collapse" id="navbarNav">
                @if (Session["UsuarioId"] != null)
                {
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("Index", "Eventos")"><i class="bi bi-calendar3"></i> Eventos</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("Index", "Categorias")"><i class="bi bi-tags"></i> Categorías</a>
                        </li>
                        @if (Session["UsuarioRol"] != null && Session["UsuarioRol"].ToString() == "Admin")
                        {
                            <li class="nav-item">
                                <a class="nav-link" href="@Url.Action("Index", "Reportes")">
                                    <i class="bi bi-file-earmark-pdf"></i> Reportes
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="@Url.Action("Index", "Usuarios")"><i class="bi bi-people"></i> Usuarios</a>
                            </li>
                        }
                    </ul>
                    <ul class="navbar-nav">
                        <li class="nav-item dropdown profile-dropdown">
                            <a class="nav-link dropdown-toggle user-info" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-person-circle"></i> @Session["UsuarioNombre"]
                            </a>
                            <div class="dropdown-menu dropdown-menu-end">
                                <div class="profile-header">
                                    <i class="bi bi-person-circle"></i>
                                    <h6>@Session["UsuarioNombre"]</h6>
                                    <small>@Session["UsuarioCorreo"]</small>
                                    <br />
                                    <span class="badge mt-2" style="background-color: #7c3aed;">@(Session["UsuarioRol"].ToString() == "Usuario" ? "Aprendiz" : Session["UsuarioRol"].ToString())</span>
                                </div>
                                <div class="profile-info">
                                    <p><i class="bi bi-envelope"></i> @Session["UsuarioCorreo"]</p>
                                    <p><i class="bi bi-shield-check"></i> Rol: @(Session["UsuarioRol"].ToString() == "Usuario" ? "Aprendiz" : Session["UsuarioRol"].ToString())</p>
                                </div>
                                <hr style="border-color: #2d2d44; margin: 10px 0;" />
                                <div class="text-center">
                                    <a href="@Url.Action("Logout", "Usuarios")" class="btn btn-sm btn-danger w-100">
                                        <i class="bi bi-box-arrow-right"></i> Cerrar Sesión
                                    </a>
                                </div>
                            </div>
                        </li>
                    </ul>
                }
            </div>
        </div>
    </nav>

    <div class="container-main">
        @RenderBody()
    </div>

    @if (Session["UsuarioId"] != null)
    {
        <button class="chatbot-btn" id="chatbotBtn" title="Asistente EventBot">
            <i class="bi bi-robot"></i>
        </button>

        <div class="chatbot-panel" id="chatbotPanel">
            <div class="chatbot-header">
                <span><i class="bi bi-robot"></i> EventBot</span>
                <button id="chatbotClose" type="button" aria-label="Cerrar chatbot"><i class="bi bi-x-lg"></i></button>
            </div>
            <div class="chatbot-messages" id="chatbotMessages">
                <div class="chat-msg bot">¡Hola! Soy EventBot, tu asistente de EventPlus. ¿En qué puedo ayudarte?</div>
            </div>
            <div class="typing-indicator" id="typingIndicator">EventBot está escribiendo...</div>
            <div class="chatbot-input">
                <input type="text" id="chatbotInput" placeholder="Escribe tu mensaje..." aria-label="Mensaje para EventBot" />
                <button id="chatbotSend" type="button" aria-label="Enviar mensaje"><i class="bi bi-send"></i></button>
            </div>
        </div>
    }

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // ===== LOGICA CONTROL DE TEMA (CLARO/OSCURO) =====
            const btnToggle = document.getElementById('btnThemeToggle');
            const themeIcon = document.getElementById('themeIcon');
            const htmlElement = document.documentElement;

            // Leer preferencia guardada o asignar Modo Oscuro por defecto
            const temaGuardado = localStorage.getItem('theme') || 'dark';

            function aplicarTema(tema) {
                if (tema === 'light') {
                    htmlElement.setAttribute('data-theme', 'light');
                    if (themeIcon) themeIcon.className = 'bi bi-sun-fill';
                } else {
                    htmlElement.removeAttribute('data-theme');
                    if (themeIcon) themeIcon.className = 'bi bi-moon-stars-fill';
                }
            }

            // Aplicar tema al cargar
            aplicarTema(temaGuardado);

            // Toggle de tema
            if (btnToggle) {
                btnToggle.addEventListener('click', function () {
                    const temaActual = htmlElement.getAttribute('data-theme');
                    const nuevoTema = temaActual === 'light' ? 'dark' : 'light';

                    aplicarTema(nuevoTema);
                    localStorage.setItem('theme', nuevoTema);
                });
            }

            // ===== LOGICA DEL CHATBOT =====
            const chatbotBtn = document.getElementById('chatbotBtn');
            const chatbotPanel = document.getElementById('chatbotPanel');
            const chatbotClose = document.getElementById('chatbotClose');
            const chatbotInput = document.getElementById('chatbotInput');
            const chatbotSend = document.getElementById('chatbotSend');
            const chatbotMessages = document.getElementById('chatbotMessages');
            const typingIndicator = document.getElementById('typingIndicator');

            if (chatbotBtn) {
                chatbotBtn.addEventListener('click', function () {
                    chatbotPanel.classList.toggle('active');
                    if (chatbotPanel.classList.contains('active')) {
                        chatbotInput.focus();
                    }
                });

                chatbotClose.addEventListener('click', function () {
                    chatbotPanel.classList.remove('active');
                });

                chatbotSend.addEventListener('click', enviarMensaje);
                chatbotInput.addEventListener('keypress', function (e) {
                    if (e.key === 'Enter' && !e.shiftKey) {
                        e.preventDefault();
                        enviarMensaje();
                    }
                });
            }

            function enviarMensaje() {
                const mensaje = chatbotInput.value.trim();
                if (mensaje === '') return;

                chatbotSend.disabled = true;
                chatbotInput.disabled = true;

                agregarMensaje(mensaje, 'user');
                chatbotInput.value = '';

                typingIndicator.style.display = 'block';
                chatbotMessages.scrollTop = chatbotMessages.scrollHeight;

                const xhr = new XMLHttpRequest();
                xhr.timeout = 25000;
                xhr.open('POST', '/Chatbot/Enviar', true);
                xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');

                xhr.onreadystatechange = function () {
                    if (xhr.readyState === 4) {
                        typingIndicator.style.display = 'none';
                        chatbotSend.disabled = false;
                        chatbotInput.disabled = false;
                        chatbotInput.focus();

                        if (xhr.status === 200) {
                            try {
                                const data = JSON.parse(xhr.responseText);
                                agregarMensaje(data.respuesta || 'No recibí una respuesta válida.', 'bot');
                            } catch (error) {
                                agregarMensaje('El servidor respondió con un formato inesperado.', 'bot');
                            }
                        } else {
                            agregarMensaje('Error de conexión. Intenta de nuevo.', 'bot');
                        }
                    }
                };

                xhr.ontimeout = function () {
                    typingIndicator.style.display = 'none';
                    chatbotSend.disabled = false;
                    chatbotInput.disabled = false;
                    chatbotInput.focus();
                    agregarMensaje('La respuesta tardó demasiado. Intenta de nuevo.', 'bot');
                };

                xhr.send('mensaje=' + encodeURIComponent(mensaje));
            }

            function agregarMensaje(texto, tipo) {
                const div = document.createElement('div');
                div.className = 'chat-msg ' + tipo;
                div.textContent = texto;
                chatbotMessages.appendChild(div);
                chatbotMessages.scrollTop = chatbotMessages.scrollHeight;
            }
        });
    </script>

    @RenderSection("scripts", required: false)
</body>
</html>
