@model EventPlusWeb1.Models.Entities.Evento
@{
    ViewBag.Title = "Eliminar Evento - " + Model.NombreEvento;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-danger p-4">
                <div class="card-body text-center text-white">
                    <i class="bi bi-exclamation-triangle text-danger" style="font-size: 4rem;"></i>
                    <h3 class="card-title text-danger mt-3">¿Confirmar Eliminación?</h3>
                    <p class="text-white-50 mt-2">
                        Estás a punto de eliminar permanentemente este evento. Esta acción no se puede deshacer.
                    </p>

                    <div class="my-4 p-3 bg-dark rounded text-start">
                        <p class="mb-2"><strong>Evento:</strong> @Model.NombreEvento</p>
                        <p class="mb-2"><strong>Fecha:</strong> @Model.FechaInicioEvento.ToString("dd/MM/yyyy")</p>
                        <p class="mb-2"><strong>Lugar:</strong> @Model.LugarEvento</p>
                        <p class="mb-0"><strong>Tipo:</strong> @Model.TipoEvento</p>
                    </div>

                    @using (Html.BeginForm("Eliminar", "Eventos", new { id = Model.IdEvento }, FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()
                        <div class="d-grid gap-2 d-md-flex justify-content-md-center mt-4">
                            <button type="submit" class="btn btn-danger btn-lg px-4">
                                <i class="bi bi-trash"></i> Eliminar Evento
                            </button>
                            <a href="@Url.Action("Index", "Eventos")" class="btn btn-secondary btn-lg px-4">
                                <i class="bi bi-x-circle"></i> Cancelar
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>