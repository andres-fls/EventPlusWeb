@model EventPlusWeb1.Models.Entities.Evento
@{
    ViewBag.Title = "Eliminar Evento";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center" style="margin-top: 40px;">
    <div class="col-md-6">
        <div class="card p-4 text-center">
            <i class="bi bi-exclamation-triangle" style="font-size: 3rem; color: #dc2626;"></i>
            <h3 style="color: #fca5a5; margin-top: 15px;">¿Eliminar este evento?</h3>
            <p style="color: #888; margin-top: 10px;">Esta acción no se puede deshacer. Se eliminarán también todas las inscripciones asociadas.</p>

            <div style="background-color: #0f3460; border-radius: 8px; padding: 15px; margin: 20px 0; text-align: left;">
                <p style="color: #a78bfa; font-weight: bold; margin-bottom: 5px;">@Model.Titulo</p>
                <p style="color: #ccc; font-size: 0.9rem; margin-bottom: 5px;">
                    <i class="bi bi-calendar3"></i> @Model.FechaEvento.ToString("dd/MM/yyyy")
                </p>
                <p style="color: #ccc; font-size: 0.9rem; margin-bottom: 0;">
                    <i class="bi bi-geo-alt"></i> @Model.Ubicacion
                </p>
            </div>

            <div class="d-flex justify-content-center gap-3">
                <form method="post" action="@Url.Action("Eliminar", "Eventos", new { id = Model.Id })">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash"></i> Sí, Eliminar
                    </button>
                </form>
                <a href="@Url.Action("Index", "Eventos")" class="btn btn-outline-light">
                    <i class="bi bi-arrow-left"></i> Cancelar
                </a>
            </div>
        </div>
    </div>
</div>