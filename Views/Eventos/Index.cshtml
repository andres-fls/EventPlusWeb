@model List<EventPlusWeb1.Models.Entities.Evento>
@{
    ViewBag.Title = "Eventos";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var isAdmin = Session["UsuarioRol"] != null && Session["UsuarioRol"].ToString() == "Admin";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 style="color: #a78bfa;"><i class="bi bi-calendar3"></i> Eventos</h2>
    @if (isAdmin)
    {
        <a href="@Url.Action("Crear", "Eventos")" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Nuevo Evento
        </a>
    }
</div>

@if (TempData["Mensaje"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Mensaje"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (Model == null || Model.Count == 0)
{
    <div class="card p-4 text-center">
        <i class="bi bi-calendar-x" style="font-size: 3rem; color: #7c3aed;"></i>
        <p style="color: #888; margin-top: 15px;">No hay eventos registrados.</p>
    </div>
}
else
{
    <div class="row">
        @foreach (var evento in Model)
        {
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card h-100">
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <span class="badge" style="background-color: #7c3aed;">@evento.NombreCategoria</span>
                            <small style="color: #888;">@evento.FechaInicioEvento.ToString("dd/MM/yyyy")</small>
                        </div>
                        <h5 class="card-title" style="color: #a78bfa;">@evento.NombreEvento</h5>
                        <p class="card-text" style="color: #ccc; font-size: 0.9rem;">
                            @if (evento.DescripcionEvento != null && evento.DescripcionEvento.Length > 100)
                            {
                                @evento.DescripcionEvento.Substring(0, 100)<text>...</text>
                            }
                            else
                            {
                                @evento.DescripcionEvento
                            }
                        </p>
                        <div style="margin-top: auto;">
                            <p style="color: #888; font-size: 0.85rem; margin-bottom: 5px;">
                                <i class="bi bi-geo-alt"></i> @evento.LugarEvento
                            </p>
                            <p style="color: #888; font-size: 0.85rem; margin-bottom: 5px;">
                                <i class="bi bi-people"></i> @evento.Inscritos / @evento.CupoMaximo inscritos
                            </p>
                            <p style="color: #888; font-size: 0.85rem; margin-bottom: 5px;">
                                <i class="bi bi-tag"></i> @evento.TipoEvento
                            </p>
                            <p style="color: #888; font-size: 0.85rem;">
                                @if (evento.EstadoEvento == "Activo")
                                {
                                    <span class="badge bg-success">Activo</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">@evento.EstadoEvento</span>
                                }
                            </p>
                            <div class="d-flex gap-2">
                                <a href="@Url.Action("Detalle", "Eventos", new { id = evento.IdEvento })" class="btn btn-sm btn-primary">
                                    <i class="bi bi-eye"></i> Ver
                                </a>
                                @if (isAdmin)
                                {
                                    <a href="@Url.Action("Editar", "Eventos", new { id = evento.IdEvento })" class="btn btn-sm btn-outline-light">
                                        <i class="bi bi-pencil"></i> Editar
                                    </a>
                                    <button type="button" class="btn btn-sm btn-danger" data-bs-toggle="modal" data-bs-target="#confirmDeleteModal_@evento.IdEvento">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                }
                                else if (evento.EstadoEvento == "Activo" && evento.FechaFinInscripcion >= DateTime.Now)
                                {
                                    <a href="@Url.Action("Inscribirse", "Eventos", new { id = evento.IdEvento })" class="btn btn-sm btn-success">
                                        <i class="bi bi-person-plus"></i> Inscribirse
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            if (isAdmin)
            {
                <div class="modal fade" id="confirmDeleteModal_@evento.IdEvento" tabindex="-1" aria-labelledby="confirmDeleteModalLabel_@evento.IdEvento" aria-hidden="true">
                    <div class="modal-dialog">
                        <div class="modal-content card">
                            <div class="modal-header border-bottom-0">
                                <h5 class="modal-title text-white" id="confirmDeleteModalLabel_@evento.IdEvento">Confirmar Eliminación</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                            </div>
                            <div class="modal-body text-white">
                                ¿Estás seguro de que deseas eliminar el evento "@evento.NombreEvento"?
                            </div>
                            <div class="modal-footer border-top-0">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                                @using (Html.BeginForm("Eliminar", "Eventos", new { id = evento.IdEvento }, FormMethod.Post))
                                {
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-danger">Eliminar</button>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
}
