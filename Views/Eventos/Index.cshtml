@model List<EventPlusWeb1.Models.Entities.Evento>
@{
    ViewBag.Title = "Eventos";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 style="color: #a78bfa;"><i class="bi bi-calendar3"></i> Eventos</h2>
    @if (Session["UsuarioRol"]?.ToString() == "Admin")
    {
        <a href="@Url.Action("Crear", "Eventos")" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Nuevo Evento
        </a>
    }
</div>

@if (Model.Count == 0)
{
    <div class="card p-4 text-center">
        <i class="bi bi-calendar-x" style="font-size: 3rem; color: #7c3aed;"></i>
        <p style="color: #888; margin-top: 15px;">No hay eventos registrados.</p>
    </div>
}
else
{
    <div class="row">
        @foreach (var evento in Model)
        {
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card h-100">
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <span class="badge" style="background-color: #7c3aed;">@evento.CategoriaNombre</span>
                            <small style="color: #888;">@evento.FechaEvento.ToString("dd/MM/yyyy")</small>
                        </div>
                        <h5 class="card-title" style="color: #a78bfa;">@evento.Titulo</h5>
                        <p class="card-text" style="color: #ccc; font-size: 0.9rem;">
                            @(evento.Descripcion != null && evento.Descripcion.Length > 100 ? evento.Descripcion.Substring(0, 100) + "..." : evento.Descripcion)
                        </p>
                        <div style="margin-top: auto;">
                            <p style="color: #888; font-size: 0.85rem; margin-bottom: 5px;">
                                <i class="bi bi-geo-alt"></i> @evento.Ubicacion
                            </p>
                            <p style="color: #888; font-size: 0.85rem;">
                                <i class="bi bi-person"></i> @evento.CreadorNombre
                            </p>
                            <div class="d-flex gap-2">
                                <a href="@Url.Action("Detalle", "Eventos", new { id = evento.Id })" class="btn btn-sm btn-primary">
                                    <i class="bi bi-eye"></i> Ver
                                </a>
                                @if (Session["UsuarioRol"]?.ToString() == "Admin")
                                {
                                    <a href="@Url.Action("Editar", "Eventos", new { id = evento.Id })" class="btn btn-sm btn-outline-light">
                                        <i class="bi bi-pencil"></i> Editar
                                    </a>
                                    <a href="@Url.Action("Eliminar", "Eventos", new { id = evento.Id })" class="btn btn-sm btn-danger">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                }
                                @if (Session["UsuarioRol"]?.ToString() == "Usuario")
                                {
                                    <a href="@Url.Action("Inscribirse", "Eventos", new { id = evento.Id })" class="btn btn-sm btn-success">
                                        <i class="bi bi-check-circle"></i> Inscribirse
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}