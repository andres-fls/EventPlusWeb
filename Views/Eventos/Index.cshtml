@model List<EventPlusWeb1.Models.Entities.Evento>
@{
    ViewBag.Title = "Eventos";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var isAdmin = Session["UsuarioRol"] != null && Session["UsuarioRol"].ToString() == "Admin";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 style="color: #a78bfa;"><i class="bi bi-calendar3"></i> Eventos</h2>
    @if (isAdmin)
    {
        <a href="@Url.Action("Crear", "Eventos")" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Nuevo Evento
        </a>
    }
</div>

@if (TempData["Mensaje"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Mensaje"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row mb-4">
    <div class="col-md-4 col-sm-6">
        <div class="card p-3">
            @using (Html.BeginForm("Index", "Eventos", FormMethod.Get))
            {
                <label for="filtroMes" class="form-label font-weight-bold mb-2" style="color: #a78bfa;">
                    <i class="bi bi-filter"></i> Filtrar por Mes:
                </label>
                <select id="filtroMes" name="mes" class="form-select" onchange="this.form.submit()">
                    <option value="0" @(ViewBag.MesSeleccionado == 0 ? "selected" : "")>-- Todos los meses --</option>
                    <option value="1" @(ViewBag.MesSeleccionado == 1 ? "selected" : "")>Enero</option>
                    <option value="2" @(ViewBag.MesSeleccionado == 2 ? "selected" : "")>Febrero</option>
                    <option value="3" @(ViewBag.MesSeleccionado == 3 ? "selected" : "")>Marzo</option>
                    <option value="4" @(ViewBag.MesSeleccionado == 4 ? "selected" : "")>Abril</option>
                    <option value="5" @(ViewBag.MesSeleccionado == 5 ? "selected" : "")>Mayo</option>
                    <option value="6" @(ViewBag.MesSeleccionado == 6 ? "selected" : "")>Junio</option>
                    <option value="7" @(ViewBag.MesSeleccionado == 7 ? "selected" : "")>Julio</option>
                    <option value="8" @(ViewBag.MesSeleccionado == 8 ? "selected" : "")>Agosto</option>
                    <option value="9" @(ViewBag.MesSeleccionado == 9 ? "selected" : "")>Septiembre</option>
                    <option value="10" @(ViewBag.MesSeleccionado == 10 ? "selected" : "")>Octubre</option>
                    <option value="11" @(ViewBag.MesSeleccionado == 11 ? "selected" : "")>Noviembre</option>
                    <option value="12" @(ViewBag.MesSeleccionado == 12 ? "selected" : "")>Diciembre</option>
                </select>
            }
        </div>
    </div>
</div>

@if (Model == null || Model.Count == 0)
{
    <div class="card p-4 text-center">
        <i class="bi bi-calendar-x" style="font-size: 3rem; color: #7c3aed;"></i>
        <p style="color: #888; margin-top: 15px;">No hay eventos registrados para este criterio.</p>
    </div>
}
else
{
    <div class="row">
        @foreach (var evento in Model)
        {
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card evento-card h-100">
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <span class="badge" style="background-color: #7c3aed;">@evento.NombreCategoria</span>
                            <small style="color: #888;">@evento.FechaInicioEvento.ToString("dd/MM/yyyy")</small>
                        </div>
                        <h5 class="card-title" style="color: #a78bfa;">@evento.NombreEvento</h5>
                        <p class="card-text" style="color: #ccc; font-size: 0.9rem;">
                            @if (evento.DescripcionEvento != null && evento.DescripcionEvento.Length > 100)
                            {
                                @evento.DescripcionEvento.Substring(0, 100)<text>...</text>
                            }
                            else
                            {
                                @evento.DescripcionEvento
                            }
                        </p>
                        <div style="margin-top: auto;">
                            <p style="color: #888; font-size: 0.85rem; margin-bottom: 5px;">
                                <i class="bi bi-geo-alt"></i> @evento.LugarEvento
                            </p>
                            <p style="color: #888; font-size: 0.85rem; margin-bottom: 5px;">
                                <i class="bi bi-people"></i> @evento.Inscritos / @evento.CupoMaximo inscritos
                            </p>
                            <p style="color: #888; font-size: 0.85rem; margin-bottom: 5px;">
                                <i class="bi bi-tag"></i> @evento.TipoEvento
                            </p>
                            <p style="color: #888; font-size: 0.85rem;">
                                @if (evento.EstadoEvento == "Activo")
                                {
                                    <span class="badge bg-success">Activo</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">@evento.EstadoEvento</span>
                                }
                            </p>
                            <div class="d-flex gap-2">
                                <a href="@Url.Action("Detalle", "Eventos", new { id = evento.IdEvento })" class="btn btn-sm btn-primary">
                                    <i class="bi bi-eye"></i> Ver
                                </a>
                                @if (isAdmin)
                                {
                                    <a href="@Url.Action("Editar", "Eventos", new { id = evento.IdEvento })" class="btn btn-sm btn-outline-light">
                                        <i class="bi bi-pencil"></i> Editar
                                    </a>
                                    <button type="button" class="btn btn-sm btn-danger" data-bs-toggle="modal" data-bs-target="#confirmDeleteModal_@evento.IdEvento">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                }
                                else if (evento.EstadoEvento == "Activo" && evento.FechaFinInscripcion >= EventPlusWeb1.Helpers.DateTimeHelper.AhoraEnColombia())
                                {
                                    if (string.Equals(evento.TipoEvento, "Individual", StringComparison.OrdinalIgnoreCase))
                                    {
                                        using (Html.BeginForm("Inscribirse", "Eventos", FormMethod.Post))
                                        {
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="eventoId" value="@evento.IdEvento" />
                                            <button type="submit" class="btn btn-sm btn-success">
                                                <i class="bi bi-person-plus"></i> Inscribirse
                                            </button>
                                        }
                                    }
                                    else if (string.Equals(evento.TipoEvento, "Grupal", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <a href="@Url.Action("Detalle", "Eventos", new { id = evento.IdEvento })" class="btn btn-sm btn-info">
                                            <i class="bi bi-people"></i> Ver Grupos
                                        </a>
                                    }
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            if (isAdmin)
            {
                <div class="modal fade" id="confirmDeleteModal_@evento.IdEvento" tabindex="-1" aria-labelledby="confirmDeleteModalLabel_@evento.IdEvento" aria-hidden="true">
                    <div class="modal-dialog">
                        <div class="modal-content card">
                            <div class="modal-header border-bottom-0">
                                <h5 class="modal-title text-white" id="confirmDeleteModalLabel_@evento.IdEvento">Confirmar Eliminación</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                            </div>
                            <div class="modal-body text-white">
                                ¿Estás seguro de que deseas eliminar el evento "@evento.NombreEvento"?
                            </div>
                            <div class="modal-footer border-top-0">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                                @using (Html.BeginForm("Eliminar", "Eventos", new { id = evento.IdEvento }, FormMethod.Post))
                                {
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-danger">Eliminar</button>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
}