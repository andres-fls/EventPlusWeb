@model EventPlusWeb1.Models.Entities.Evento
@{
    ViewBag.Title = "Unirme a un Grupo - " + Model.NombreEvento;
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-white"><i class="bi bi-arrow-right-circle"></i> Unirme a un grupo existente</h2>
    </div>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-circle"></i>
            @ViewBag.Error
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row">
        <div class="col-lg-8">
            <!-- Tarjeta del evento -->
            <div class="card p-4 mb-4">
                <h5 class="text-white mb-3"><i class="bi bi-calendar-event"></i> Información del evento</h5>
                <div class="row">
                    <div class="col-md-6">
                        <p class="mb-2">
                            <span class="text-white-50">Evento:</span>
                            <strong class="text-white">@Model.NombreEvento</strong>
                        </p>
                        <p class="mb-2">
                            <span class="text-white-50">Categoría:</span>
                            <strong class="text-white">@Model.NombreCategoria</strong>
                        </p>
                    </div>
                    <div class="col-md-6">
                        <p class="mb-2">
                            <span class="text-white-50">Lugar:</span>
                            <strong class="text-white">@Model.LugarEvento</strong>
                        </p>
                        <p class="mb-0">
                            <span class="text-white-50">Fecha:</span>
                            <strong class="text-white">@Model.FechaInicioEvento.ToString("dd/MM/yyyy")</strong>
                        </p>
                    </div>
                </div>
            </div>

            <!-- Formulario unirse a grupo -->
            <div class="card p-4 mb-4">
                <h5 class="text-white mb-4"><i class="bi bi-pencil-square"></i> Ingresa el código del grupo</h5>

                <form action="@Url.Action("UnirseGrupo", "Eventos")" method="post">
                    @Html.AntiForgeryToken()

                    <input type="hidden" name="eventoId" value="@Model.IdEvento" />

                    <div class="mb-4">
                        <label for="codigo" class="form-label">
                            <i class="bi bi-key"></i> Código del grupo
                        </label>
                        <input 
                            type="text" 
                            id="codigo" 
                            name="codigo" 
                            class="form-control form-control-lg text-uppercase" 
                            placeholder="Ej: GRP-7K2X" 
                            required 
                            maxlength="20"
                            style="letter-spacing: 2px; font-weight: 600;"
                            autofocus />
                        <small class="form-text text-white-50 d-block mt-2">
                            Solicita el código al líder del grupo. Será convertido automáticamente a mayúsculas.
                        </small>
                    </div>

                    <div class="d-grid gap-2 d-md-flex justify-content-md-start">
                        <button type="submit" class="btn btn-info btn-lg">
                            <i class="bi bi-check-circle"></i> Unirme al grupo
                        </button>
                        <a href="@Url.Action("Detalle", "Eventos", new { id = Model.IdEvento })" class="btn btn-secondary btn-lg">
                            <i class="bi bi-x-circle"></i> Cancelar
                        </a>
                    </div>
                </form>
            </div>

            <!-- Información de ayuda -->
            <div class="card p-4 bg-secondary-light border-warning">
                <h6 class="card-title text-white mb-3">
                    <i class="bi bi-question-circle"></i> ¿No recibiste el código?
                </h6>
                <p class="text-white-50 small mb-0">
                    Comunícate con el líder de tu grupo para que te comparta el código. 
                    El código es único para cada grupo y debe ser ingresado exactamente como fue generado.
                </p>
            </div>
        </div>

        <!-- Sidebar: información adicional -->
        <div class="col-lg-4">
            <div class="card p-4 mb-4 border-info">
                <h6 class="card-title text-white mb-3">
                    <i class="bi bi-info-circle"></i> Pasos para unirte
                </h6>
                <ol class="text-white-50 small">
                    <li>Recibe el código del líder del grupo (ej: GRP-7K2X)</li>
                    <li>Ingresa el código en el campo anterior</li>
                    <li>Haz clic en "Unirme al grupo"</li>
                    <li>¡Listo! Ya estarás inscrito en el grupo</li>
                </ol>
            </div>

            <div class="card p-4 border-success">
                <h6 class="card-title text-white mb-3">
                    <i class="bi bi-shield-check"></i> Validaciones
                </h6>
                <ul class="list-unstyled text-white-50 small mb-0">
                    <li><i class="bi bi-exclamation-circle"></i> El código debe ser válido</li>
                    <li><i class="bi bi-exclamation-circle"></i> El grupo debe tener cupo disponible</li>
                    <li><i class="bi bi-exclamation-circle"></i> No puedes unirte dos veces al mismo evento</li>
                </ul>
            </div>

            <div class="card p-4 mt-4 bg-info bg-opacity-10 border-info">
                <h6 class="card-title text-white mb-3">
                    <i class="bi bi-lightbulb"></i> Consejo
                </h6>
                <p class="text-white-50 small mb-0">
                    Asegúrate de copiar el código exactamente como aparece. 
                    Los códigos contienen letras y números sin caracteres confusos.
                </p>
            </div>
        </div>
    </div>

    <div class="mt-4">
        <a href="@Url.Action("Index", "Eventos")" class="btn btn-outline-light">
            <i class="bi bi-arrow-left"></i> Volver a eventos
        </a>
    </div>
</div>

<style>
    .bg-secondary-light {
        background-color: rgba(75, 85, 99, 0.1) !important;
    }

    [data-theme="light"] .bg-secondary-light {
        background-color: #f9fafb !important;
    }

    [data-theme="light"] .bg-info {
        background-color: rgba(79, 172, 254, 0.1) !important;
    }
</style>
