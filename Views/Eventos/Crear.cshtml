@model EventPlusWeb1.Models.Entities.Evento
@{
    ViewBag.Title = "Crear Evento";
    IEnumerable<SelectListItem> categorias = ViewBag.Categorias;
    List<SelectListItem> tiposEvento = new List<SelectListItem>
{
        new SelectListItem { Text = "Individual", Value = "Individual" },
        new SelectListItem { Text = "Grupal", Value = "Grupal" }
    };
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-white"><i class="bi bi-plus-circle"></i> Crear Nuevo Evento</h2>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card p-4">
        @using (Html.BeginForm("Crear", "Eventos", FormMethod.Post, new { @class = "row g-3" }))
        {
            @Html.AntiForgeryToken()

            <div class="col-md-6">
                <label for="NombreEvento" class="form-label">@Html.DisplayNameFor(model => model.NombreEvento)</label>
                @Html.EditorFor(model => model.NombreEvento, new { htmlAttributes = new { @class = "form-control", oninput = "this.value = this.value.replace(/[^a-zA-ZáéíóúÁÉÍÓÚñÑ ]/g, '')" } })
                @Html.ValidationMessageFor(model => model.NombreEvento, "", new { @class = "text-danger" })
            </div>
            <div class="col-md-6">
                <label for="Categoria_idCategoria" class="form-label">Categoría</label>
                @Html.DropDownListFor(model => model.Categoria_idCategoria, categorias, "-- Seleccione una Categoría --", new { @class = "form-select" })
                @Html.ValidationMessageFor(model => model.Categoria_idCategoria, "", new { @class = "text-danger" })
            </div>

            <div class="col-12">
                <label for="DescripcionEvento" class="form-label">@Html.DisplayNameFor(model => model.DescripcionEvento)</label>
                @Html.TextAreaFor(model => model.DescripcionEvento, new { @class = "form-control", rows = 5 })
                @Html.ValidationMessageFor(model => model.DescripcionEvento, "", new { @class = "text-danger" })
            </div>

            <div class="col-md-6">
                <label for="LugarEvento" class="form-label">@Html.DisplayNameFor(model => model.LugarEvento)</label>
                @Html.EditorFor(model => model.LugarEvento, new { htmlAttributes = new { @class = "form-control" } })
                @Html.ValidationMessageFor(model => model.LugarEvento, "", new { @class = "text-danger" })
            </div>
            <div class="col-md-6">
                <label for="CupoMaximo" class="form-label">@Html.DisplayNameFor(model => model.CupoMaximo)</label>
                @Html.EditorFor(model => model.CupoMaximo, new { htmlAttributes = new { @class = "form-control", type = "number" } })
                @Html.ValidationMessageFor(model => model.CupoMaximo, "", new { @class = "text-danger" })
            </div>

            <div class="col-md-6">
                <label for="FechaInicioEvento" class="form-label">@Html.DisplayNameFor(model => model.FechaInicioEvento)</label>
                @Html.EditorFor(model => model.FechaInicioEvento, new { htmlAttributes = new { @class = "form-control", type = "datetime-local", id = "FechaInicioEvento" } })
                @Html.ValidationMessageFor(model => model.FechaInicioEvento, "", new { @class = "text-danger" })
            </div>
            <div class="col-md-6">
                <label for="FechaFinEvento" class="form-label">@Html.DisplayNameFor(model => model.FechaFinEvento)</label>
                @Html.EditorFor(model => model.FechaFinEvento, new { htmlAttributes = new { @class = "form-control", type = "datetime-local", id = "FechaFinEvento" } })
                @Html.ValidationMessageFor(model => model.FechaFinEvento, "", new { @class = "text-danger" })
            </div>

            <div class="col-md-6">
                <label for="FechaInicioInscripcion" class="form-label">@Html.DisplayNameFor(model => model.FechaInicioInscripcion)</label>
                @Html.EditorFor(model => model.FechaInicioInscripcion, new { htmlAttributes = new { @class = "form-control", type = "datetime-local", id = "FechaInicioInscripcion" } })
                @Html.ValidationMessageFor(model => model.FechaInicioInscripcion, "", new { @class = "text-danger" })
            </div>
            <div class="col-md-6">
                <label for="FechaFinInscripcion" class="form-label">@Html.DisplayNameFor(model => model.FechaFinInscripcion)</label>
                @Html.EditorFor(model => model.FechaFinInscripcion, new { htmlAttributes = new { @class = "form-control", type = "datetime-local", id = "FechaFinInscripcion" } })
                @Html.ValidationMessageFor(model => model.FechaFinInscripcion, "", new { @class = "text-danger" })
            </div>

            <div class="col-md-6">
                <label for="TipoEvento" class="form-label">@Html.DisplayNameFor(model => model.TipoEvento)</label>
                @Html.DropDownListFor(model => model.TipoEvento, tiposEvento, "-- Seleccione Tipo --", new { @class = "form-select" })
                @Html.ValidationMessageFor(model => model.TipoEvento, "", new { @class = "text-danger" })
            </div>

            <div class="col-12 mt-4">
                <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> Crear Evento</button>
                <a href="@Url.Action("Index", "Eventos")" class="btn btn-secondary ms-2"><i class="bi bi-arrow-left"></i> Cancelar</a>
            </div>
        }
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")

    <script type="text/javascript">
        document.addEventListener("DOMContentLoaded", function () {
            // 1. Obtener el momento actual exacto en formato local (YYYY-MM-DDTHH:mm)
            const ahora = new Date();
            const yyyy = ahora.getFullYear();
            let mm = ahora.getMonth() + 1;
            let dd = ahora.getDate();
            let hh = ahora.getHours();
            let min = ahora.getMinutes();

            if (mm < 10) mm = '0' + mm;
            if (dd < 10) dd = '0' + dd;
            if (hh < 10) hh = '0' + hh;
            if (min < 10) min = '0' + min;

            const fechaMinima = `${yyyy}-${mm}-${dd}T${hh}:${min}`;

            // 2. Capturar los 4 inputs de fechas de tu formulario
            const inputsFechas = [
                document.getElementById("FechaInicioEvento"),
                document.getElementById("FechaFinEvento"),
                document.getElementById("FechaInicioInscripcion"),
                document.getElementById("FechaFinInscripcion")
            ];

            // 3. Bloquear días pasados directamente en los calendarios flotantes
            inputsFechas.forEach(input => {
                if (input) {
                    input.setAttribute("min", fechaMinima);

                    // 4. Lanzar alerta inmediata si intentan digitar de forma manual una fecha vieja
                    input.addEventListener("change", function () {
                        if (this.value && this.value < fechaMinima) {
                            alert("⚠️ Error: No se permite seleccionar fechas ni horas previas al momento actual.");
                            this.value = ""; // Limpia el input de inmediato
                        }
                    });
                }
            });
        });
    </script>
}