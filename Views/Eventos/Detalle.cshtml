@model EventPlusWeb1.Models.Entities.Evento
@{
    ViewBag.Title = "Detalle del Evento";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-white"><i class="bi bi-info-circle"></i> Detalle del Evento</h2>
    </div>

    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Mensaje"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card p-4 mb-4">
        <h3 class="text-white mb-3">@Html.DisplayFor(model => model.NombreEvento)</h3>
        <hr class="border-secondary" />
        <div class="row">
            <div class="col-md-6">
                <dl class="row">
                    <dt class="col-sm-4 text-white-50">@Html.DisplayNameFor(model => model.NombreCategoria)</dt>
                    <dd class="col-sm-8 text-white">@Html.DisplayFor(model => model.NombreCategoria)</dd>

                    <dt class="col-sm-4 text-white-50">@Html.DisplayNameFor(model => model.LugarEvento)</dt>
                    <dd class="col-sm-8 text-white">@Html.DisplayFor(model => model.LugarEvento)</dd>

                    <dt class="col-sm-4 text-white-50">@Html.DisplayNameFor(model => model.FechaInicioEvento)</dt>
                    <dd class="col-sm-8 text-white">@Model.FechaInicioEvento.ToString("dd/MM/yyyy HH:mm")</dd>

                    <dt class="col-sm-4 text-white-50">@Html.DisplayNameFor(model => model.FechaFinEvento)</dt>
                    <dd class="col-sm-8 text-white">@Model.FechaFinEvento.ToString("dd/MM/yyyy HH:mm")</dd>

                    <dt class="col-sm-4 text-white-50">@Html.DisplayNameFor(model => model.TipoEvento)</dt>
                    <dd class="col-sm-8 text-white">@Html.DisplayFor(model => model.TipoEvento)</dd>

                    <dt class="col-sm-4 text-white-50">@Html.DisplayNameFor(model => model.EstadoEvento)</dt>
                    <dd class="col-sm-8 text-white">
                        @if (Model.EstadoEvento == "Activo")
                        {
                            <span class="badge bg-success">Activo</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">@Html.DisplayFor(model => model.EstadoEvento)</span>
                        }
                    </dd>
                </dl>
            </div>
            <div class="col-md-6">
                <dl class="row">
                    <dt class="col-sm-4 text-white-50">@Html.DisplayNameFor(model => model.FechaInicioInscripcion)</dt>
                    <dd class="col-sm-8 text-white">@Model.FechaInicioInscripcion.ToString("dd/MM/yyyy HH:mm")</dd>

                    <dt class="col-sm-4 text-white-50">@Html.DisplayNameFor(model => model.FechaFinInscripcion)</dt>
                    <dd class="col-sm-8 text-white">@Model.FechaFinInscripcion.ToString("dd/MM/yyyy HH:mm")</dd>

                    <dt class="col-sm-4 text-white-50">@Html.DisplayNameFor(model => model.CupoMaximo)</dt>
                    <dd class="col-sm-8 text-white">@Html.DisplayFor(model => model.CupoMaximo)</dd>

                    <dt class="col-sm-4 text-white-50">Inscritos</dt>
                    <dd class="col-sm-8 text-white">@Model.Inscritos</dd>

                    <dt class="col-sm-4 text-white-50">@Html.DisplayNameFor(model => model.NombreCreador)</dt>
                    <dd class="col-sm-8 text-white">@Html.DisplayFor(model => model.NombreCreador)</dd>
                </dl>
            </div>
        </div>
        <div class="mt-3">
            <h5 class="text-white-50">@Html.DisplayNameFor(model => model.DescripcionEvento)</h5>
            <p class="text-white">@Html.Raw(Model.DescripcionEvento.Replace("\n", "<br/>"))</p>
        </div>
    </div>

    <div class="mt-4">
        <a href="@Url.Action("Index", "Eventos")" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Volver a la lista</a>
    </div>
</div>
